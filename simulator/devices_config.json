{
  "description": "木牛流马传感器设备配置文件",
  "version": "1.0",
  "devices": [
    {
      "device_id": "woodox_001",
      "name": "木牛流马一号原型机",
      "use_tcp": true,
      "host": "localhost",
      "port": 502,
      "serial_port": "COM1",
      "baudrate": 9600,
      "slave_id": 1,
      "poll_interval": 60,
      "location": "实验室A区",
      "description": "用于平地行走测试"
    },
    {
      "device_id": "woodox_002",
      "name": "木牛流马二号原型机",
      "use_tcp": true,
      "host": "localhost",
      "port": 503,
      "serial_port": "COM2",
      "baudrate": 9600,
      "slave_id": 1,
      "poll_interval": 60,
      "location": "实验室B区",
      "description": "用于越障测试"
    },
    {
      "device_id": "woodox_003",
      "name": "木牛流马三号原型机",
      "use_tcp": true,
      "host": "localhost",
      "port": 504,
      "serial_port": "COM3",
      "baudrate": 9600,
      "slave_id": 1,
      "poll_interval": 60,
      "location": "实验室C区",
      "description": "用于稳定性测试"
    }
  ],
  "modbus_register_map": {
    "description": "Modbus寄存器映射表",
    "registers": [
      {
        "address": 0,
        "name": "CRANK_ANGLE_HIGH",
        "type": "float32",
        "description": "曲柄转角(高字)",
        "unit": "度",
        "range": "0-360"
      },
      {
        "address": 1,
        "name": "CRANK_ANGLE_LOW",
        "type": "float32",
        "description": "曲柄转角(低字)",
        "unit": "度",
        "range": "0-360"
      },
      {
        "address": 2,
        "name": "LEG_DISPLACEMENT_HIGH",
        "type": "float32",
        "description": "腿足位移(高字)",
        "unit": "mm",
        "range": "0-500"
      },
      {
        "address": 3,
        "name": "LEG_DISPLACEMENT_LOW",
        "type": "float32",
        "description": "腿足位移(低字)",
        "unit": "mm",
        "range": "0-500"
      },
      {
        "address": 4,
        "name": "BODY_INCLINATION_HIGH",
        "type": "float32",
        "description": "机身倾角(高字)",
        "unit": "度",
        "range": "-90-90"
      },
      {
        "address": 5,
        "name": "BODY_INCLINATION_LOW",
        "type": "float32",
        "description": "机身倾角(低字)",
        "unit": "度",
        "range": "-90-90"
      },
      {
        "address": 6,
        "name": "GROUND_ELEVATION_HIGH",
        "type": "float32",
        "description": "地面起伏(高字)",
        "unit": "mm",
        "range": "-500-500"
      },
      {
        "address": 7,
        "name": "GROUND_ELEVATION_LOW",
        "type": "float32",
        "description": "地面起伏(低字)",
        "unit": "mm",
        "range": "-500-500"
      },
      {
        "address": 8,
        "name": "DEVICE_STATUS",
        "type": "uint16",
        "description": "设备状态字",
        "bit_definitions": {
          "bit0": "NORMAL - 正常运行",
          "bit1": "WARNING - 警告状态",
          "bit2": "ERROR - 错误状态",
          "bit3": "JAMMED - 机构卡死"
        }
      },
      {
        "address": 9,
        "name": "TIMESTAMP_HIGH",
        "type": "uint16",
        "description": "时间戳(高16位)"
      },
      {
        "address": 10,
        "name": "TIMESTAMP_LOW",
        "type": "uint16",
        "description": "时间戳(低16位)"
      },
      {
        "address": 11,
        "name": "CRC_HIGH",
        "type": "uint16",
        "description": "CRC校验(高字)"
      },
      {
        "address": 12,
        "name": "CRC_LOW",
        "type": "uint16",
        "description": "CRC校验(低字)"
      }
    ]
  },
  "alert_thresholds": {
    "body_inclination_max": 15.0,
    "mechanism_jam_min_change": 5.0,
    "consecutive_readings_required": 3,
    "alert_cooldown_seconds": 60
  }
}
